#!/bin/bash
# YouTube再生リストからObsidianレシピを自動生成
# 使い方:
#   recipe                           # デフォルトの再生リストを処理
#   recipe https://youtube.com/...   # 指定URLを処理

URL="${1:-https://www.youtube.com/playlist?list=PLh4huXs8Qi9HkMIXptPbw2gIYUDNtqNic}"
SCRIPT="$HOME/scripts/transcribe.py"
RECIPE_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Obsidian/Vault/レシピ"
TRANSCRIPT_DIR="${RECIPE_DIR}/_transcripts"

echo "=== Step 1/2: 文字起こし ==="
if ! "$HOME/scripts/.venv/bin/python3" "$SCRIPT" "$URL"; then
  echo "文字起こしでエラーが発生しました（一部失敗の可能性あり）。"
  echo "成功分のレシピ変換を続行します..."
fi

echo ""
echo "=== Step 2/2: レシピ化 ==="
COUNT=$(find "$TRANSCRIPT_DIR" -maxdepth 1 -name '*.txt' 2>/dev/null | wc -l | tr -d ' ')
if [ "$COUNT" = "0" ]; then
  echo "文字起こしファイルがありません。完了済みか、Step 1が失敗しています。"
  exit 0
fi
echo "${COUNT}件の文字起こしをレシピに変換中..."

DONE=0
FAIL=0
for TXT in "$TRANSCRIPT_DIR"/*.txt; do
  [ -f "$TXT" ] || continue
  NAME=$(basename "$TXT")
  echo ""
  echo "[$((DONE + FAIL + 1))/${COUNT}] ${NAME}"

  if claude -p "
$(cat "$TXT")

---
上の文字起こしをObsidianレシピ形式に変換して ${RECIPE_DIR} に保存して。
ファイル名は料理名.md にして。

フォーマット:
---
created: (現在日時)
updated: (現在日時)
source: (動画URL ※文字起こしヘッダのurlを使う)
---
# 料理名
* 材料 分量
1. 手順
"; then
    mkdir -p "${TRANSCRIPT_DIR}/done"
    mv "$TXT" "${TRANSCRIPT_DIR}/done/"
    DONE=$((DONE + 1))
    echo "  → 完了"
  else
    FAIL=$((FAIL + 1))
    echo "  → 失敗"
  fi
done

echo ""
echo "=== 完了 ==="
echo "成功: ${DONE}件 / 失敗: ${FAIL}件"
