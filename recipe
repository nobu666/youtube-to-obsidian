#!/bin/bash
# YouTube再生リストからObsidianレシピを自動生成
# 使い方:
#   recipe                           # デフォルトの再生リストを処理
#   recipe https://youtube.com/...   # 指定URLを処理

# caffeinate で再帰呼び出し（スリープ防止）
if [ -z "$CAFFEINATED" ]; then
  exec env CAFFEINATED=1 caffeinate -i "$0" "$@"
fi

URL="${1:-https://www.youtube.com/playlist?list=PLh4huXs8Qi9HkMIXptPbw2gIYUDNtqNic}"
SCRIPT="$HOME/scripts/transcribe.py"
RECIPE_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Obsidian/Vault/レシピ"
TRANSCRIPT_DIR="${RECIPE_DIR}/.transcripts"

echo "=== Step 1/2: 文字起こし ==="
if ! nice -n 10 "$HOME/scripts/.venv/bin/python3" "$SCRIPT" "$URL"; then
  echo "文字起こしでエラーが発生しました（一部失敗の可能性あり）。"
  echo "成功分のレシピ変換を続行します..."
fi

echo ""
echo "=== Step 2/2: レシピ化 ==="
COUNT=$(find "$TRANSCRIPT_DIR" -maxdepth 1 -name '*.txt' 2>/dev/null | wc -l | tr -d ' ')
if [ "$COUNT" = "0" ]; then
  echo "文字起こしファイルがありません。完了済みか、Step 1が失敗しています。"
  exit 0
fi
echo "${COUNT}件の文字起こしをレシピに変換中..."

trap 'echo ""; echo "中断しました。"; exit 130' INT

DONE_DIR="${TRANSCRIPT_DIR}/done"
mkdir -p "$DONE_DIR"

DONE=0
FAIL=0
FAILED_FILES=()
RESULTS=()
for TXT in "$TRANSCRIPT_DIR"/*.txt; do
  [ -f "$TXT" ] || continue
  NAME=$(basename "$TXT")
  TITLE=$(head -1 "$TXT" | sed 's/^title: //')
  echo ""
  echo "[$((DONE + FAIL + 1))/${COUNT}] ${NAME}"

  BEFORE_COUNT=$(find "$RECIPE_DIR" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
  OUTPUT=$(nice -n 10 claude -p --dangerously-skip-permissions "
$(cat "$TXT")

---
上の文字起こしをObsidianレシピ形式に変換して ${RECIPE_DIR} に保存して。
ファイル名は料理名.md にして。
ルール:
- 質問・確認・提案は一切しない。すべて自分で判断して完了まで進めること。
- 文字起こしの品質が低くても、読み取れる範囲で最善のレシピを作る。
- 内容が全く読み取れない場合だけファイルを作らず、その旨を1行で出力して終了。
- 補足や注意点があれば、レシピファイル保存後に1〜2行で簡潔に報告する。

フォーマット:
---
created: (現在日時)
updated: (現在日時)
source: (動画URL ※文字起こしヘッダのurlを使う)
---
# 料理名
* 材料 分量
1. 手順
" 2>&1)
  AFTER_COUNT=$(find "$RECIPE_DIR" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
  if [ "$AFTER_COUNT" -gt "$BEFORE_COUNT" ]; then
    mv "$TXT" "$DONE_DIR/"
    DONE=$((DONE + 1))
    RESULTS+=("✓ ${TITLE}|${OUTPUT}")
    echo "  → 完了"
  else
    FAIL=$((FAIL + 1))
    FAILED_FILES+=("$TXT")
    RESULTS+=("✗ ${TITLE}|${OUTPUT}")
    echo "  → 失敗"
  fi
done

echo ""
echo "=== 完了 ==="
echo "成功: ${DONE}件 / 失敗: ${FAIL}件"

if [ ${#RESULTS[@]} -gt 0 ]; then
  echo ""
  echo "=== 処理結果 ==="
  for R in "${RESULTS[@]}"; do
    HEADER="${R%%|*}"
    BODY="${R#*|}"
    echo ""
    echo "--- ${HEADER} ---"
    echo "$BODY"
  done
fi

if [ ${#FAILED_FILES[@]} -gt 0 ]; then
  echo ""
  echo "=== 失敗したファイル ==="
  for F in "${FAILED_FILES[@]}"; do
    VIDEO_ID=$(basename "$F" .txt)
    TITLE=$(head -1 "$F" | sed 's/^title: //')
    echo "  - ${TITLE} (${VIDEO_ID})"
    echo "    https://www.youtube.com/watch?v=${VIDEO_ID}"
  done
  echo ""
  echo "対応方法:"
  echo "  1. そのまま再実行（失敗分だけリトライされる）:"
  echo "     ~/scripts/recipe"
  echo "  2. 文字起こしからやり直す（文字起こし品質が原因の場合）:"
  echo "     rm \"${TRANSCRIPT_DIR}/<video_id>.txt\""
  echo "     ~/scripts/recipe \"https://www.youtube.com/watch?v=<video_id>\""
  echo "  3. 動画を直接見てObsidianに手動で書く"
fi
